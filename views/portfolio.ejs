<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= page.title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="stylesheet" href="/portfolio-legacy.css?v=20260425-option-settlement" />
    <link rel="stylesheet" href="/portfolio-bridge.css?v=20260425-option-settlement" />
  </head>
  <body class="portfolio-page" data-page="<%= page.pageKey %>">
    <% const isTransactionsPage = page.pageKey === "portfolio-transactions"; %>
    <% const isHistoryPage = page.pageKey === "portfolio-history"; %>
    <% const isRealizedPnlPage = page.pageKey === "portfolio-realized-pnl"; %>
    <% const isReviewPage = page.pageKey === "portfolio-review"; %>
    <% const portfolioSubnav = [
      { href: "/portfolio", label: "持仓总览", kicker: "Overview", active: !isTransactionsPage && !isHistoryPage && !isRealizedPnlPage && !isReviewPage },
      { href: "/portfolio/transactions", label: "交易流水", kicker: "Ledger", active: isTransactionsPage },
      { href: "/portfolio/history", label: "历史已清仓", kicker: "History", active: isHistoryPage },
      { href: "/portfolio/realized-pnl", label: "已实现盈亏", kicker: "PnL", active: isRealizedPnlPage },
      { href: "/portfolio/review", label: "组合复盘", kicker: "Review", active: isReviewPage }
    ]; %>
    <div class="aurora aurora-left"></div>
    <div class="aurora aurora-right"></div>

    <div class="site-shell">
      <%- include("partials/header", { site, currentPath }) %>

      <main class="doc-page">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <% page.breadcrumb.forEach((item, index) => { %>
            <% if (index > 0) { %><span>/</span><% } %>
            <% if (item.href) { %>
              <a href="<%= item.href %>"><%= item.label %></a>
            <% } else { %>
              <span class="is-current"><%= item.label %></span>
            <% } %>
          <% }) %>
        </nav>

        <div class="page-shell portfolio-shell">
          <div class="portfolio-layout">
            <aside class="portfolio-directory card" aria-label="持仓工具目录">
              <div class="card-heading">
                <h2>持仓工具目录</h2>
              </div>
              <nav class="portfolio-directory-nav">
                <% portfolioSubnav.forEach((item) => { %>
                  <a class="portfolio-directory-link <%= item.active ? 'is-current' : '' %>" href="<%= item.href %>" aria-current="<%= item.active ? 'page' : 'false' %>">
                    <strong><%= item.label %></strong>
                  </a>
                <% }) %>
              </nav>
            </aside>

            <div class="portfolio-main">
          <header class="hero">
            <div class="hero-copy">
              <p class="eyebrow"><%= page.hero.eyebrow %></p>
              <h1><%= page.hero.title %></h1>
              <p class="hero-text"><%= page.hero.description %></p>
              <div class="badge-row">
                <% (page.hero.badges || []).forEach((badge) => { %>
                  <span><%= badge %></span>
                <% }) %>
              </div>
            </div>

            <section class="quick-actions card">
              <div class="card-heading">
                <h2>当前状态</h2>
                <p id="user-badge">请先登录后查看个人投资总览</p>
              </div>
              <div class="action-row user-actions">
                <button id="logout-btn" class="ghost-button is-hidden">退出登录</button>
              </div>
              <div class="status-block">
                <span class="status-chip">美元总账</span>
                <span class="status-chip">T-1 行情</span>
                <span class="status-chip">Yahoo 代理</span>
              </div>
              <div class="legacy-actions is-hidden" aria-hidden="true">
                <button id="refresh-prices-btn" class="ghost-button">刷新行情</button>
                <button id="load-sample-btn" class="ghost-button">载入示例数据</button>
                <button id="reset-btn" class="ghost-button danger">清空当前数据</button>
                <button id="export-btn" class="ghost-button">导出 JSON</button>
                <label class="import-label ghost-button" for="import-file">导入 JSON</label>
                <input id="import-file" type="file" accept="application/json" hidden />
              </div>
              <p id="sync-status" class="sync-status">页面刷新时会优先从 MySQL 缓存同步股票、期权、加密货币和贵金属 / 外汇的 T-1 价格，未命中时再请求本地 Yahoo 代理服务。</p>
            </section>
          </header>

          <section id="auth-panel" class="auth-panel card">
            <div class="card-heading">
              <h2>登录 / 注册</h2>
              <p>每个用户只会看到自己的持仓数据</p>
            </div>

            <div class="auth-layout">
              <form id="auth-form" class="auth-form" novalidate>
                <h3>输入账号后自动登录 / 注册</h3>
                <label>
                  用户名
                  <input id="auth-username" type="text" autocomplete="username" />
                </label>
                <label>
                  密码
                  <input id="auth-password" type="password" autocomplete="current-password" />
                </label>
                <p class="form-hint">输入用户名和密码后，已存在用户会直接登录；新用户会自动注册并登录。首个注册用户会自动接管当前数据库里尚未归属的历史持仓。</p>
                <button id="auth-submit-btn" type="submit" class="primary-button">继续</button>
              </form>
            </div>

            <p id="auth-status" class="sync-status">登录后才能查看、编辑和同步属于你自己的持仓。</p>
          </section>

          <section id="dashboard" class="dashboard is-hidden">
            <section class="summary-grid <%= (isTransactionsPage || isHistoryPage || isRealizedPnlPage || isReviewPage) ? 'is-hidden' : '' %>">
              <article class="metric-card">
                <span class="metric-label">总资产</span>
                <strong id="total-assets" class="metric-value">$0.00</strong>
                <span class="metric-note">持仓市值 + 现金</span>
              </article>
              <article class="metric-card">
                <span class="metric-label">现金</span>
                <strong id="total-cash" class="metric-value">$0.00</strong>
                <span class="metric-note">已单独从持仓市值里拆出</span>
              </article>
              <article class="metric-card">
                <span class="metric-label">持仓市值</span>
                <strong id="total-market-value" class="metric-value">$0.00</strong>
                <span class="metric-note">仅统计非现金持仓</span>
              </article>
              <article class="metric-card">
                <span class="metric-label">持仓盈亏</span>
                <strong id="total-pnl" class="metric-value">$0.00</strong>
                <span id="total-pnl-rate" class="metric-note">持仓收益率 0.00%</span>
              </article>
            </section>

            <section class="overview-trend-grid <%= (isTransactionsPage || isHistoryPage || isRealizedPnlPage || isReviewPage) ? 'is-hidden' : '' %>">
              <article class="card trend-card">
                <div class="mini-chart-head">
                  <h3>净值趋势</h3>
                  <span>总资产</span>
                </div>
                <div id="overview-nav-trend" class="sparkline-card empty-state">还没有足够的净值快照。</div>
              </article>

              <article class="card trend-card">
                <div class="mini-chart-head">
                  <h3>现金趋势</h3>
                  <span>可用现金</span>
                </div>
                <div id="overview-cash-trend" class="sparkline-card empty-state">还没有足够的现金快照。</div>
              </article>

              <article class="card trend-card">
                <div class="mini-chart-head">
                  <h3>盈亏趋势</h3>
                  <span>总盈亏</span>
                </div>
                <div id="overview-pnl-trend" class="sparkline-card empty-state">还没有足够的盈亏快照。</div>
              </article>
            </section>

            <section class="portfolio-toolbar card <%= (isTransactionsPage || isHistoryPage || isRealizedPnlPage || isReviewPage) ? 'is-hidden' : '' %>">
              <div class="card-heading">
                <div>
                  <h2>当前操作</h2>
                  <p>把录入动作收进弹窗，把总览页留给查看、筛选和判断。</p>
                </div>
                <div class="action-row">
                  <button id="open-holding-modal-btn" type="button" class="primary-button">新增持仓</button>
                  <button id="refresh-prices-btn-inline" type="button" class="ghost-button">刷新行情</button>
                </div>
              </div>
              <div class="action-row">
                <button id="load-sample-btn-inline" type="button" class="ghost-button">载入示例数据</button>
                <button id="export-btn-inline" type="button" class="ghost-button">导出 JSON</button>
                <label class="import-label ghost-button" for="import-file-inline">导入 JSON</label>
                <input id="import-file-inline" type="file" accept="application/json" hidden />
                <button id="reset-btn-inline" type="button" class="ghost-button danger">清空当前数据</button>
              </div>
            </section>

            <section class="card insight-card <%= (isTransactionsPage || isHistoryPage || isRealizedPnlPage || isReviewPage) ? 'is-hidden' : '' %>">
                <div class="card-heading">
                  <h2>仓位洞察</h2>
                  <p>资产类别、平台和目标仓位偏差</p>
                </div>

                <section class="mini-chart-grid">
                  <article class="mini-chart-card">
                    <div class="mini-chart-head">
                      <h3>资产分布图</h3>
                      <span>按市值</span>
                    </div>
                    <div id="asset-allocation-chart" class="mini-chart empty-state">暂无图表数据</div>
                  </article>

                  <article class="mini-chart-card">
                    <div class="mini-chart-head">
                      <h3>平台分布图</h3>
                      <span>按市值</span>
                    </div>
                    <div id="platform-allocation-chart" class="mini-chart empty-state">暂无图表数据</div>
                  </article>
                </section>

                <div class="insight-group">
                  <h3>资产类别分布</h3>
                  <div id="asset-allocation" class="stack-list empty-state"></div>
                </div>

                <div class="insight-group">
                  <h3>平台分布</h3>
                  <div id="platform-allocation" class="stack-list empty-state"></div>
                </div>

                <div class="insight-group">
                  <h3>目标仓位偏差</h3>
                  <div id="allocation-gap" class="gap-list empty-state"></div>
                </div>
            </section>

            <section class="card table-card <%= (isTransactionsPage || isHistoryPage || isRealizedPnlPage || isReviewPage) ? 'is-hidden' : '' %>">
              <div class="card-heading">
                <h2>全部持仓</h2>
                <p>支持按平台统一查看股票、期权、加密货币、贵金属和外汇的状态</p>
              </div>

              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>
                        <div class="table-head-control">
                          <span>资产</span>
                          <select id="filter-asset-type">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>平台</span>
                          <select id="filter-platform">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>市场</span>
                          <select id="filter-market">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>数量 / 张数</th>
                      <th>
                        <div class="table-head-control">
                          <span>成本</span>
                          <select id="sort-cost">
                            <option value="">默认</option>
                            <option value="costDesc">从高到低</option>
                            <option value="costAsc">从低到高</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>市值</span>
                          <select id="sort-market-value">
                            <option value="marketValueDesc">从高到低</option>
                            <option value="marketValueAsc">从低到高</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>盈亏</span>
                          <select id="sort-pnl">
                            <option value="">默认</option>
                            <option value="pnlDesc">从高到低</option>
                            <option value="pnlAsc">从低到高</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>仓位</span>
                          <select id="sort-allocation">
                            <option value="">默认</option>
                            <option value="allocationDesc">从高到低</option>
                            <option value="allocationAsc">从低到高</option>
                          </select>
                        </div>
                      </th>
                      <th>操作</th>
                    </tr>
                  </thead>
                  <tbody id="holdings-table-body">
                    <tr>
                      <td colspan="9" class="empty-row">还没有持仓，先录入一条数据吧。</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="card table-card <%= isTransactionsPage ? '' : 'is-hidden' %>">
              <div class="card-heading">
                <h2>交易流水</h2>
                <p>按时间倒序查看开仓、加仓、减仓、清仓和现金流动作，方便复盘每一笔交易。</p>
              </div>

              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>交易日期</th>
                      <th>
                        <div class="table-head-control">
                          <span>类型</span>
                          <select id="tx-filter-type">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>资产</span>
                          <select id="tx-filter-asset-type">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>平台</span>
                          <select id="tx-filter-platform">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>搜索</span>
                          <input id="tx-search" type="text" placeholder="代码 / 名称 / 备注" />
                        </div>
                      </th>
                      <th>数量</th>
                      <th>成交价</th>
                      <th>净额</th>
                      <th>已实现盈亏</th>
                      <th>来源</th>
                      <th>操作</th>
                    </tr>
                  </thead>
                  <tbody id="transactions-table-body">
                    <tr>
                      <td colspan="11" class="empty-row">登录后这里会显示你的交易流水。</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="card table-card <%= isHistoryPage ? '' : 'is-hidden' %>">
              <div class="card-heading">
                <h2>历史已清仓</h2>
                <p>已经退出的仓位都会归档在这里，方便按标的、平台和已实现盈亏做复盘。</p>
              </div>

              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>清仓日期</th>
                      <th>
                        <div class="table-head-control">
                          <span>资产类型</span>
                          <select id="closed-filter-asset-type">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>平台</span>
                          <select id="closed-filter-platform">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>搜索</span>
                          <input id="closed-search" type="text" placeholder="代码 / 名称 / 备注" />
                        </div>
                      </th>
                      <th>清仓价</th>
                      <th>已实现盈亏</th>
                      <th>备注</th>
                    </tr>
                  </thead>
                  <tbody id="closed-holdings-table-body">
                    <tr>
                      <td colspan="7" class="empty-row">登录后这里会显示历史已清仓仓位。</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="card table-card <%= isRealizedPnlPage ? '' : 'is-hidden' %>">
              <div class="card-heading">
                <h2>已实现盈亏</h2>
                <p>每一条记录都来自已实现盈亏台账，方便按日期、平台和标的查看真正落袋的结果。</p>
              </div>

              <section class="mini-chart-card section-chart">
                <div class="mini-chart-head">
                  <h3>已实现盈亏分布</h3>
                  <span>按交易</span>
                </div>
                <div id="realized-pnl-chart" class="mini-chart empty-state">还没有已实现盈亏图表数据。</div>
              </section>

              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>结算日期</th>
                      <th>
                        <div class="table-head-control">
                          <span>资产类型</span>
                          <select id="rp-filter-asset-type">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>平台</span>
                          <select id="rp-filter-platform">
                            <option value="">全部</option>
                          </select>
                        </div>
                      </th>
                      <th>
                        <div class="table-head-control">
                          <span>搜索</span>
                          <input id="rp-search" type="text" placeholder="代码 / 名称 / 备注" />
                        </div>
                      </th>
                      <th>平仓数量</th>
                      <th>卖出 / 回补金额</th>
                      <th>成本</th>
                      <th>已实现盈亏</th>
                      <th>备注</th>
                    </tr>
                  </thead>
                  <tbody id="realized-pnl-table-body">
                    <tr>
                      <td colspan="9" class="empty-row">登录后这里会显示你的已实现盈亏台账。</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="review-grid <%= isReviewPage ? '' : 'is-hidden' %>">
              <section class="summary-grid">
                <article class="metric-card">
                  <span class="metric-label">组合净值</span>
                  <strong id="review-total-nav" class="metric-value">$0.00</strong>
                  <span class="metric-note">当前所有持仓按美元汇总的净值</span>
                </article>
                <article class="metric-card">
                  <span class="metric-label">已实现盈亏</span>
                  <strong id="review-realized-pnl" class="metric-value">$0.00</strong>
                  <span id="review-win-rate" class="metric-note">胜率 0.00%</span>
                </article>
                <article class="metric-card">
                  <span class="metric-label">未实现盈亏</span>
                  <strong id="review-unrealized-pnl" class="metric-value">$0.00</strong>
                  <span class="metric-note">当前持仓对应的浮动盈亏</span>
                </article>
                <article class="metric-card">
                  <span class="metric-label">当前现金</span>
                  <strong id="review-cash" class="metric-value">$0.00</strong>
                  <span class="metric-note">现金持仓按美元折算后的合计</span>
                </article>
              </section>

              <section class="card table-card">
                <div class="card-heading">
                  <h2>复盘指标</h2>
                  <p>先展示当前账本里可以稳定算出来的指标，后面再继续扩展回撤、月度收益等。</p>
                </div>
                <div id="review-metrics-list" class="stack-list empty-state"></div>
              </section>

              <section class="review-analytics-grid">
                <section class="card table-card">
                  <div class="card-heading">
                    <h2>最大回撤</h2>
                    <p>基于已落库净值快照回看峰值到低点的最大跌幅。</p>
                  </div>
                  <div id="review-drawdown-card" class="stack-list empty-state">还没有足够的净值快照来计算最大回撤。</div>
                </section>

                <section class="card table-card">
                  <div class="card-heading">
                    <h2>收益区间</h2>
                    <p>看当前快照序列里区间收益、最佳日和最差日的波动表现。</p>
                  </div>
                  <div id="review-return-band-chart" class="mini-chart empty-state">还没有足够的收益区间图表数据。</div>
                </section>

                <section class="card table-card review-analytics-wide">
                  <div class="card-heading">
                    <h2>资产类型收益对比</h2>
                    <p>按资产类型汇总总盈亏，对比哪一类资产正在贡献收益，哪一类正在拖累表现。</p>
                  </div>
                  <div id="asset-type-pnl-chart" class="mini-chart empty-state">还没有足够的资产类型收益对比数据。</div>
                </section>
              </section>

              <section class="card table-card">
                <div class="card-heading">
                  <div>
                    <h2>净值曲线</h2>
                    <p>用当前已落库的净值快照画出趋势线，历史会从今天开始逐步沉淀。</p>
                  </div>
                </div>
                <div id="nav-series-chart" class="nav-chart empty-state">还没有历史净值曲线，系统会从今天开始持续沉淀。</div>
              </section>

              <section class="card table-card">
                <div class="card-heading">
                  <h2>净值快照</h2>
                  <p>净值快照从今天开始持续落库。若历史快照为空，不会伪造过去的曲线。</p>
                </div>
                <div class="table-wrapper">
                  <table>
                    <thead>
                      <tr>
                        <th>日期</th>
                        <th>净值</th>
                        <th>现金</th>
                        <th>市值</th>
                        <th>未实现盈亏</th>
                        <th>已实现盈亏</th>
                        <th>总盈亏</th>
                      </tr>
                    </thead>
                    <tbody id="nav-series-table-body">
                      <tr>
                        <td colspan="7" class="empty-row">登录后这里会显示净值快照。</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </section>
            </section>
          </section>
        </div>

        <template id="allocation-item-template">
          <article class="stack-item">
            <div>
              <strong class="stack-title"></strong>
              <span class="stack-caption"></span>
            </div>
            <strong class="stack-value"></strong>
          </article>
        </template>

        <div id="holding-modal" class="trade-modal is-hidden" aria-hidden="true">
          <div id="holding-modal-backdrop" class="trade-modal-backdrop"></div>
          <section class="trade-modal-card card holding-modal-card" role="dialog" aria-modal="true" aria-labelledby="holding-modal-title">
            <div class="card-heading">
              <div>
                <h2 id="holding-modal-title">新增持仓</h2>
                <p id="holding-modal-subtitle">录入每个平台上的股票、期权、现金和加密货币持仓。</p>
              </div>
            </div>

            <form id="holding-form" class="holding-form" novalidate>
              <input type="hidden" id="holding-id" />

              <div class="form-grid">
                <label>
                  资产类型
                  <select id="asset-type" required>
                    <option value="stock">股票</option>
                    <option value="option">期权</option>
                    <option value="cash">现金</option>
                    <option value="crypto">加密货币</option>
                    <option value="macro">贵金属 / 外汇</option>
                  </select>
                </label>

                <label>
                  所在平台
                  <select id="platform" required>
                    <option value="IBKR">IBKR</option>
                    <option value="Futu">Futu</option>
                    <option value="Longbridge">盈立</option>
                    <option value="Tiger">老虎</option>
                    <option value="Phillip">辉立</option>
                    <option value="OKX">OKX</option>
                    <option value="Zhuorui">卓锐</option>
                  </select>
                </label>

                <label>
                  市场
                  <select id="market" required>
                    <option value="US">美股</option>
                    <option value="KR">韩股</option>
                    <option value="CRYPTO">Crypto</option>
                    <option value="FX">外汇 / 贵金属</option>
                  </select>
                </label>

                <label id="position-side-field" class="is-hidden">
                  仓位方向
                  <select id="position-side">
                    <option value="long">买方</option>
                    <option value="short">卖方</option>
                  </select>
                </label>

                <label>
                  代码
                  <input id="symbol" type="text" placeholder="如 AAPL / BTC / XAUUSD" required />
                </label>

                <label>
                  名称
                  <input id="name" type="text" placeholder="如 Apple / Bitcoin / Gold Spot" required />
                </label>

                <label>
                  币种
                  <select id="currency" required>
                    <option value="USD">USD</option>
                    <option value="HKD">HKD</option>
                    <option value="KRW">KRW</option>
                    <option value="USDT">USDT</option>
                    <option value="USDC">USDC</option>
                    <option value="CUSTOM">其他</option>
                  </select>
                  <input id="currency-custom" class="is-hidden" type="text" maxlength="10" placeholder="自定义币种" />
                </label>

                <label>
                  <span id="quantity-label">持仓数量</span>
                  <input id="quantity" type="number" min="0" step="any" placeholder="0" required />
                </label>

                <label id="cost-price-field">
                  <span id="cost-price-label">成本价</span>
                  <input id="cost-price" type="number" min="0" step="any" placeholder="0" required />
                </label>

                <label id="current-price-field">
                  <span id="current-price-label">现价</span>
                  <input id="current-price" type="number" min="0" step="any" placeholder="0" required />
                  <button id="lookup-price-btn" type="button" class="ghost-button inline-lookup-button">获取 T-1 价格</button>
                </label>

                <label>
                  <span id="fx-rate-label">汇率到基准币</span>
                  <input id="fx-rate" type="number" min="0" step="any" placeholder="如 1 / 0.00073" required />
                </label>

                <label>
                  目标仓位 %
                  <input id="target-allocation" type="number" min="0" max="100" step="any" placeholder="可选" />
                </label>

                <label>
                  备注
                  <input id="notes" type="text" placeholder="如 长线 / 波段 / 现货" />
                </label>
              </div>

              <section id="option-fields" class="option-section is-hidden">
                <div class="option-grid">
                  <label>
                    标的资产
                    <input id="underlying" type="text" placeholder="如 TSLA / NVDA" />
                  </label>

                  <label>
                    期权类型
                    <select id="option-type">
                      <option value="call">Call</option>
                      <option value="put">Put</option>
                    </select>
                  </label>

                  <label>
                    行权价
                    <input id="strike-price" type="number" min="0" step="any" placeholder="如 180" />
                  </label>

                  <label>
                    到期日
                    <input id="expiry-date" type="date" />
                  </label>

                  <label>
                    合约乘数
                    <input id="contract-multiplier" type="number" min="1" step="1" placeholder="默认 100" />
                  </label>
                </div>
              </section>

              <p class="form-hint">
                当前按美元做总账汇总。`汇率到基准币` 请填写到美元的汇率，比如美股和 USDT 资产通常填 `1`，港币资产可填 `HKD/USD`，韩股可填 `KRW/USD`；期权按每张合约的报价和乘数计算，现金只需要填金额和汇率。
              </p>
              <p id="price-lookup-status" class="sync-status">填好代码、市场和币种后，系统会先查数据库缓存，未命中时再请求 Yahoo Finance 代理服务，包括 XAUUSD / XAGUSD 这类贵金属映射。</p>
              <p id="price-lookup-source" class="sync-status is-hidden"></p>

              <div class="form-actions">
                <button type="submit" id="holding-submit-btn" class="primary-button">保存持仓</button>
                <button type="button" id="cancel-edit-btn" class="ghost-button">取消</button>
              </div>
            </form>
          </section>
        </div>

        <div id="trade-modal" class="trade-modal is-hidden" aria-hidden="true">
          <div id="trade-modal-backdrop" class="trade-modal-backdrop"></div>
          <section class="trade-modal-card card" role="dialog" aria-modal="true" aria-labelledby="trade-modal-title">
            <div class="card-heading">
              <h2 id="trade-modal-title">交易操作</h2>
              <p id="trade-modal-subtitle">填写本次加仓、减仓或清仓信息</p>
            </div>

            <form id="trade-form" class="holding-form" novalidate>
              <div class="form-grid">
                <label>
                  操作类型
                  <input id="trade-action-label" type="text" readonly />
                </label>

                <label>
                  标的
                  <input id="trade-symbol" type="text" readonly />
                </label>

                <label id="trade-quantity-field">
                  <span id="trade-quantity-label">数量</span>
                  <input id="trade-quantity" type="number" min="0" step="any" placeholder="请输入数量" />
                </label>

                <label>
                  <span id="trade-unit-price-label">成交价</span>
                  <input id="trade-unit-price" type="number" min="0" step="any" placeholder="请输入成交价" required />
                </label>

                <label>
                  交易日期
                  <input id="trade-date" type="date" required />
                </label>

                <label>
                  手续费
                  <input id="trade-fee" type="number" min="0" step="any" placeholder="默认 0" />
                </label>

                <label>
                  税费
                  <input id="trade-tax" type="number" min="0" step="any" placeholder="默认 0" />
                </label>

                <label>
                  备注
                  <input id="trade-notes" type="text" placeholder="可选" />
                </label>
              </div>

              <p id="trade-form-status" class="sync-status">提交后会同步写入持仓快照、交易流水、lots 和已实现盈亏台账。</p>

              <div class="form-actions">
                <button id="trade-submit-btn" type="submit" class="primary-button">确认提交</button>
                <button id="trade-cancel-btn" type="button" class="ghost-button">取消</button>
              </div>
            </form>
          </section>
        </div>

        <div id="option-settlement-modal" class="trade-modal is-hidden" aria-hidden="true">
          <div id="option-settlement-modal-backdrop" class="trade-modal-backdrop"></div>
          <section class="trade-modal-card card" role="dialog" aria-modal="true" aria-labelledby="option-settlement-modal-title">
            <div class="card-heading">
              <h2 id="option-settlement-modal-title">期权结算</h2>
              <p id="option-settlement-modal-subtitle">把期权结算动作同步到股票、现金和交易流水里</p>
            </div>

            <form id="option-settlement-form" class="holding-form" novalidate>
              <div class="form-grid">
                <label>
                  动作
                  <input id="option-settlement-action-label" type="text" readonly />
                </label>

                <label>
                  期权
                  <input id="option-settlement-symbol" type="text" readonly />
                </label>

                <label>
                  合约张数
                  <input id="option-settlement-quantity" type="number" min="0" step="any" placeholder="请输入张数" required />
                </label>

                <label>
                  交割股数
                  <input id="option-settlement-share-quantity" type="text" readonly />
                </label>

                <label>
                  行权 / 指派价
                  <input id="option-settlement-strike-price" type="text" readonly />
                </label>

                <label>
                  交易日期
                  <input id="option-settlement-date" type="date" required />
                </label>

                <label>
                  手续费
                  <input id="option-settlement-fee" type="number" min="0" step="any" placeholder="默认 0" />
                </label>

                <label>
                  税费
                  <input id="option-settlement-tax" type="number" min="0" step="any" placeholder="默认 0" />
                </label>

                <label>
                  备注
                  <input id="option-settlement-notes" type="text" placeholder="可选" />
                </label>
              </div>

              <p id="option-settlement-form-status" class="sync-status">提交后会自动处理期权结算，并同步股票、现金、lots 和交易流水。</p>

              <div class="form-actions">
                <button id="option-settlement-submit-btn" type="submit" class="primary-button">确认结算</button>
                <button id="option-settlement-cancel-btn" type="button" class="ghost-button">取消</button>
              </div>
            </form>
          </section>
        </div>
      </main>
    </div>

    <script src="/portfolio-app.js?v=20260425-option-settlement"></script>
  </body>
</html>
